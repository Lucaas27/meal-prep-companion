# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Supabase Auth (Google OAuth)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# Edge Function secrets (set via `npx supabase secrets set`, not .env)
# USDA_API_KEY — your USDA FoodData Central API key

# Edge Function configuration
# OPEN_FOOD_FACTS_USER_AGENT — non-secret User-Agent string for Open Food Facts requests
# Example: Meal Prep Companion/1.3 (hello@example.com)
OPEN_FOOD_FACTS_USER_AGENT=Meal Prep Companion/1.3 (hello@example.com)
